# Backend Environment Variables
# Copy this to .env and fill in your actual values

# Database Configuration
# For development, SQLite is used by default
DATABASE_URL=sqlite:///./sdirs_dev.sqlite

# For production with PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/disaster_db
# Or use a managed service:
# DATABASE_URL=postgresql://user:pass@db.host.com:5432/disaster_db

# JWT Configuration
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_YOUR_SECURE_KEY

# Redis Configuration (Optional - for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# External API Keys
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ThingSpeak IoT Sensors (get from thingspeak.com)
THINGSPEAK_CHANNEL_ID=your-channel-id
THINGSPEAK_READ_KEY=your-read-api-key

# HuggingFace NLP (get from huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twitter API v2 (for social media - optional)
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-bearer-token

# US Census Bureau (free, no key required)
# CENSUS_API_KEY=not-required

# Security Settings
# Allowed CORS origins (comma-separated) - CHANGE IN PRODUCTION
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Environment
ENVIRONMENT=development

# Logging Level
LOG_LEVEL=INFO

# Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./static/uploads

# AI/ML Settings
MODEL_PATH=./models
ENABLE_AI_VERIFICATION=true

# Socket.io Settings
SOCKET_CORS_ORIGIN=http://localhost:3000
